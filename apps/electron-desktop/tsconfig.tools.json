{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true
  },
  "include": ["vitest.config.ts", "playwright.config.ts", "e2e/**/*.ts", "test/**/*.ts"]
}
